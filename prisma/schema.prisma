// prisma/schema.prisma
datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

model Food {
  id            Int         @id @default(autoincrement())
  name          String
  calories      Float
  protein       Float
  carbohydrates Float
  fat           Float
  usageCount    BigInt      @default(0)
  createdAt     DateTime    @default(now())
  foodEntries   FoodEntry[]
  recipes     RecipeFood[]

}

model Session {
  id      Int      @id @default(autoincrement())
  token   String   @unique
  userId  Int
  user    User     @relation(fields: [userId], references: [id])
  expires DateTime
}

model Recipe {
  id          Int            @id @default(autoincrement())
  name        String
  ingredients RecipeFood[]
}

model RecipeFood {
  id        Int    @id @default(autoincrement())

  recipeId  Int
  foodId    Int

  recipe    Recipe @relation(fields: [recipeId], references: [id])
  food      Food   @relation(fields: [foodId], references: [id])

  quantity  Int
}

model KcalGoal {
  id            Int      @id @default(autoincrement())
  userId        Int
  kcal          Int
  protein       Int
  carbohydrates Int
  fats          Int
  createdAt     DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model User {
  id           Int         @id @default(autoincrement())
  email        String      @unique
  passwordHash String?
  googleId     String?  @unique
  foodEntries  FoodEntry[]
  sessions     Session[]
  goals        KcalGoal[]
}

model FoodEntry {
  id Int @id @default(autoincrement())

  userId Int
  foodId Int

  amount  Int
  eatenAt DateTime

  user User @relation(fields: [userId], references: [id])
  food Food @relation(fields: [foodId], references: [id])

  @@index([userId])
  @@index([foodId])
  @@index([eatenAt])
}
