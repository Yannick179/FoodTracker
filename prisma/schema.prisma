// prisma/schema.prisma
datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

model Session {
  id      Int      @id @default(autoincrement())
  token   String   @unique
  userId  Int
  user    User     @relation(fields: [userId], references: [id])
  expires DateTime
}

model KcalGoal {
  id            Int      @id @default(autoincrement())
  userId        Int
  kcal          Int
  protein       Int
  carbohydrates Int
  fats          Int
  createdAt     DateTime @db.Date

  user User @relation(fields: [userId], references: [id])
  @@unique([userId, createdAt])
}

model User {
  id           Int         @id @default(autoincrement())
  email        String      @unique
  passwordHash String?
  googleId     String?     @unique
  sessions     Session[]
  goals        KcalGoal[]
  mealLogs     MealLog[]
  mealTemplates MealTemplate[]

}

model Food {
  id            Int         @id @default(autoincrement())
  name          String
  calories      Float
  protein       Float
  carbohydrates Float
  fat           Float
  usageCount    BigInt      @default(0)
  createdAt     DateTime    @default(now())
  foodPortionTemplates  FoodPortionTemplate[]
  foodLogs              FoodLog[]

}

model FoodPortionTemplate {
  id             Int @id @default(autoincrement())
  foodId         Int
  mealTemplateId Int
  amount         Int

  food Food @relation(fields: [foodId], references: [id])
  mealTemplate MealTemplate @relation(fields: [mealTemplateId], references: [id])

  @@index([foodId])
  @@index([mealTemplateId])
}


model FoodLog {
    id             Int         @id @default(autoincrement())
    mealLogId      Int
    foodId         Int
    amount         Int

    food Food @relation(fields: [foodId], references: [id])
    mealLog MealLog @relation(fields: [mealLogId], references: [id], onDelete: Cascade)



}

model MealLog {
    id                  Int         @id @default(autoincrement())
    name                String      @default("")
    eatenAt             DateTime
    userId              Int

    user User @relation(fields: [userId], references: [id])

    foodLogs    FoodLog[]

}

model MealTemplate {
    id                      Int         @id @default(autoincrement())
    name                    String
    foodPortionTemplates    FoodPortionTemplate[]
    userId                  Int

    user User @relation(fields: [userId], references: [id])

}
